# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","tauri://localhost"]

# Database (use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/portfolio_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Portfolio site
PORTFOLIO_URL=https://yourportfolio.dev

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_REPO=yourusername/yourportfolio
GITHUB_WORKFLOW_ID=deploy.yml
GITHUB_DEFAULT_BRANCH=main

# Vercel (optional)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# Notifications
SENDGRID_API_KEY=
NOTIFICATION_EMAIL_FROM=agent@yourportfolio.dev
NOTIFICATION_EMAIL_TO=you@email.com
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=